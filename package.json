{
  "name": "chill-flight",
  "version": "0.9.3",
  "author": "Jimmy Orr",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/sync-metadata.js",
    "dev": "vite",
    "prebuild": "node scripts/sync-metadata.js",
    "build": "vite build",
    "release": "npm version patch --no-git-tag-version && node scripts/sync-version.js && npm run build",
    "preview": "vite preview",
    "ios": "npm run build && npx cap sync ios && npx cap open ios",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "test:syntax": "for f in *.js; do node --check \"$f\" || exit 1; done",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,css,html,md}\" --ignore-path .prettierignore"
  },
  "dependencies": {
    "@capacitor-firebase/analytics": "^8.2.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/motion": "^8.0.0",
    "@capacitor/status-bar": "^8.0.2",
    "@sentry/browser": "^8.26.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "firebase": "^12.12.1",
    "three": "^0.128.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.13"
  },
  "description": "Drift through endless, ever-changing skies to relaxing lofi beats.",
  "keywords": [
    "flight",
    "simulator",
    "chill",
    "lofi",
    "relaxing",
    "procedural",
    "flying",
    "airplanes"
  ]
}
